# Now we need to do the same for STs, but only for S. aureus and S. pneumoniae, to supplement the data 

####
# S. aureus
####

saureus <- read.csv("/12_CAS/6_ST/saureus_231_CAS_14959_public_ST_agr_spa_sccmec.csv")
dim(saureus) # 15190 (makes sense, 14959+231)

head(saureus, 2)
#                  genome agr_group spa_type  ST clonal_complex sccmec CAS_or_public
# 1 filt_CAS_0006_01_BLOO       gp1    t1541 101                  None           CAS
# 2 filt_CAS_0006_02_BLOO       gp1    t1541 101                  None           CAS

# Replace blanks in ST column with NA
saureus$ST[saureus$ST == ""] <- NA

# define ST sets
gtdb_sts <- saureus %>% filter(CAS_or_public == "public", !is.na(ST)) %>% pull(ST) %>% unique()
cas_sts <- saureus %>% filter(CAS_or_public == "CAS", !is.na(ST)) %>% pull(ST) %>% unique()

# summarise counts
saureus_st_counts <- tibble(
  Species = "Staphylococcus aureus",
  GTDB_STs = length(gtdb_sts),
  CAS_STs = length(cas_sts),
  CAS_STs_added = length(setdiff(cas_sts, gtdb_sts)),
  Total_STs_post = GTDB_STs + CAS_STs_added,
  Increase_fold = round(Total_STs_post / GTDB_STs, 2)
)

saureus_st_counts
#   Species               GTDB_STs CAS_STs CAS_STs_added Total_STs_post Increase_fold
# 1 Staphylococcus aureus      587      21             7            594          1.01

